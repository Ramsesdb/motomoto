{
  "name": "@m2/design",
  "version": "0.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": ["*.css"],
  "files": ["src", "css", "tailwind-preset.cjs"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tailwind-preset": "./src/tailwind-preset.ts",
    "./tailwind-preset.cjs": "./tailwind-preset.cjs",
    "./css/tokens.css": "./css/tokens.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rimraf .turbo"
  },
  "dependencies": {
    "@m2/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
