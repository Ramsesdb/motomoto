{
  "name": "m2-front",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "mobile": "pnpm --filter @m2/mobile",
    "mobile:start": "pnpm --filter @m2/mobile start"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "~5.9.2",
    "rimraf": "^5.0.10"
  },
  "engines": {
    "node": ">=20.19.4",
    "pnpm": ">=9.0.0"
  }
}
