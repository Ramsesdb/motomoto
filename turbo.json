{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsconfig.base.json",
    ".npmrc",
    ".eslintrc.base.cjs",
    ".prettierrc.cjs"
  ],
  "globalEnv": [
    "NODE_ENV",
    "EXPO_PUBLIC_*",
    "NEXT_PUBLIC_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "app/**",
        "i18n/**",
        "messages/**",
        "public/**",
        "middleware.ts",
        "next.config.ts",
        "next.config.js",
        "postcss.config.cjs",
        "tailwind.config.ts",
        "package.json",
        "tsconfig.json"
      ],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "src/**",
        "app/**",
        "i18n/**",
        "scripts/**",
        "middleware.ts",
        "next.config.ts",
        "next-env.d.ts",
        "tailwind.config.ts",
        "package.json",
        "tsconfig.json",
        "tsconfig.base.json"
      ],
      "outputs": []
    },
    "lint": {
      "inputs": [
        "src/**",
        "app/**",
        "i18n/**",
        "messages/**",
        "middleware.ts",
        "next.config.ts",
        ".eslintrc*",
        "package.json"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate:api": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
