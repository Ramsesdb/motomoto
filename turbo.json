{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "tsconfig.base.json",
    ".npmrc"
  ],
  "globalEnv": [
    "NODE_ENV",
    "EXPO_PUBLIC_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig.json"
      ],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": [
        "src/**",
        "app/**",
        "package.json",
        "tsconfig.json",
        "tsconfig.base.json"
      ],
      "outputs": []
    },
    "lint": {
      "inputs": [
        "src/**",
        "app/**",
        ".eslintrc*",
        "package.json"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
